# Server Config
PORT=3000
NODE_ENV=development
JWT_SECRET=replace_with_strong_jwt_secret

# Database (Neon Serverless PostgreSQL or local pg)
DATABASE_URL=postgres://user:password@ep-cool-butterfly-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# Stripe Payments (Required)
STRIPE_SECRET_KEY=sk_live_or_sk_test_key
STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_key
STRIPE_WEBHOOK_SECRET=whsec_...

# Hardhat / EVM Blockchain
# Local Hardhat defaults:
#   BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
#   BLOCKCHAIN_PRIVATE_KEY=default hardhat account #0 private key
#   BLOCKCHAIN_CONTRACT_ADDRESS=written by scripts/deploy-hardhat.js
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BLOCKCHAIN_CONTRACT_ADDRESS=0x...

# Optional: keep true for full implementation mode; set false only for local/offline testing
REQUIRE_BLOCKCHAIN_TX=true
