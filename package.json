{
  "name": "escrow-payment-system",
  "version": "1.0.0",
  "description": "Smart Contract-Based Escrow Payment System for Transportation Apps",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:client": "cd client && npm install && npm run build",
    "test": "jest tests/ --forceExit --detectOpenHandles",
    "hardhat:compile": "hardhat compile",
    "hardhat:node": "hardhat node",
    "hardhat:deploy:local": "hardhat run scripts/deploy-hardhat.js --network localhost"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.5",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "stripe": "^17.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "hardhat": "^2.26.3",
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
